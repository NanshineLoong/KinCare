WEB_PORT=8080
MCP_PORT=8081

# Required for any real deployment. The placeholder is only for local tryouts.
KINCARE_JWT_SECRET=change-me-in-production

# Optional bootstrap defaults. You can leave these unset and configure them later
# in Settings -> Admin Config after the first admin account signs in.
#
# Daily refresh schedule
# KINCARE_HEALTH_SUMMARY_REFRESH_HOUR=5
# KINCARE_HEALTH_SUMMARY_REFRESH_MINUTE=0
# KINCARE_CARE_PLAN_REFRESH_HOUR=6
# KINCARE_CARE_PLAN_REFRESH_MINUTE=0
#
# Chat model
# KINCARE_AI_BASE_URL=
# KINCARE_AI_API_KEY=
# KINCARE_AI_MODEL=gpt-4.1-mini
#
# Speech-to-text
# KINCARE_STT_PROVIDER=openai
# KINCARE_STT_API_KEY=
# KINCARE_STT_MODEL=gpt-4o-mini-transcribe
# KINCARE_STT_LANGUAGE=zh
# KINCARE_STT_TIMEOUT_SECONDS=30
#
# Local Whisper
# KINCARE_LOCAL_WHISPER_MODEL=small
# KINCARE_LOCAL_WHISPER_DEVICE=auto
# KINCARE_LOCAL_WHISPER_COMPUTE_TYPE=default
# KINCARE_LOCAL_WHISPER_DOWNLOAD_ROOT=

# Advanced deployment overrides. These are not currently exposed in Admin Config.
# KINCARE_SCHEDULER_ENABLED=1
# KINCARE_SCHEDULER_TIMEZONE=Asia/Shanghai
# KINCARE_STT_BASE_URL=
# KINCARE_STT_PROMPT=
# KINCARE_DOCLING_ARTIFACTS_PATH=
